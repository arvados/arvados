[Unit]
Description=Arvados AWS secret retrieval service
After=network.target
[Service]
# AWS_SHARED_CREDENTIALS_FILE is set to /dev/null to avoid AWS's CLI
# loading invalid credentials on nodes who use ~/.aws/credentials for other
# purposes (e.g.: the dispatcher credentials)
# Access to the secrets manager is given by using an instance profile.
Environment=AWS_SHARED_CREDENTIALS_FILE=/dev/null
Environment="AWS_REGION={{ aws_region | systemd_env_quote }}"
RuntimeDirectory=arvados
ExecStartPre=/usr/bin/mkfifo --mode=0600 %t/arvados/"{{ arvados_secret_id | systemd_exec_quote }}"
ExecStart=/usr/local/sbin/arvados-aws-secret.sh "{{ arvados_secret_id | systemd_exec_quote }}"
[Install]
WantedBy=multi-user.target
